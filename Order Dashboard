<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>TruSea Fish Daily Orders</title>
<style>
:root {
  --ocean: #0077b6;
  --sea:   #00b4d8;
  --foam:  #90e0ef;
  --deep:  #03045e;
  --fresh: #06d6a0;
  --warn:  #ffb703;
  --danger:#ef233c;
  --bg:    #f0f4f8;
  --card:  #ffffff;
  --text:  #1a1a2e;
  --muted: #6b7280;
  --border:#e2e8f0;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: var(--bg);
  color: var(--text);
  padding-bottom: 40px;
}

/* ── HEADER ── */
.header {
  background: linear-gradient(135deg, var(--deep) 0%, var(--ocean) 100%);
  padding: 14px 16px 12px;
  position: sticky;
  top: 0;
  z-index: 50;
  box-shadow: 0 2px 12px rgba(0,0,0,0.2);
}
.header-row1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}
.brand-left h1 {
  font-size: 15px;
  font-weight: 800;
  color: var(--foam);
  letter-spacing: -0.3px;
  font-style: italic;
  text-shadow: 0 1px 4px rgba(0,0,0,0.3);
  line-height: 1.2;
}
.brand-left p {
  font-size: 10px;
  color: rgba(144,224,239,0.7);
  font-weight: 500;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
.logo-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.logo-box {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: rgba(255,255,255,0.15);
  border: 2px solid rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  cursor: pointer;
}
.logo-box img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; }
.logo-box .logo-placeholder { font-size: 22px; }
.logo-upload { display: none; }
.header-actions { display: flex; gap: 6px; align-items: center; }
.icon-btn {
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 20px;
  padding: 6px 10px;
  font-size: 13px;
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 4px;
  white-space: nowrap;
}
.icon-btn:active { opacity: 0.7; }
.sync-badge {
  font-size: 10px;
  color: var(--foam);
  opacity: 0.8;
  margin-top: 2px;
}

/* ── SUMMARY STRIP ── */
.summary {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: 8px;
  padding: 12px 12px 0;
}
.sum-card {
  background: var(--card);
  border-radius: 12px;
  padding: 10px 6px;
  text-align: center;
  box-shadow: 0 1px 4px rgba(0,0,0,0.07);
}
.sum-num  { font-size: 22px; font-weight: 800; letter-spacing: -1px; }
.sum-lbl  { font-size: 10px; color: var(--muted); font-weight: 600; margin-top: 1px; text-transform: uppercase; letter-spacing: 0.3px; }
.c-blue   { color: var(--ocean); }
.c-green  { color: var(--fresh); }
.c-orange { color: var(--warn); }
.c-red    { color: var(--danger); }

/* ── SEARCH ── */
.search-wrap { padding: 10px 12px 0; position: relative; }
.search-input {
  width: 100%;
  padding: 10px 14px 10px 38px;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: 12px;
  font-size: 14px;
  outline: none;
  color: var(--text);
  transition: border 0.2s;
}
.search-input:focus { border-color: var(--ocean); }
.search-icon {
  position: absolute;
  left: 24px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 15px;
  color: var(--muted);
  pointer-events: none;
  margin-top: 5px;
}

/* ── TABS (Products / Pre-Book) ── */
.main-tabs {
  display: flex;
  gap: 0;
  padding: 10px 12px 0;
}
.main-tab {
  flex: 1;
  padding: 9px 0;
  text-align: center;
  font-size: 13px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  background: var(--card);
  color: var(--muted);
  transition: all 0.2s;
  border-bottom: 3px solid transparent;
}
.main-tab:first-child { border-radius: 12px 0 0 0; }
.main-tab:last-child  { border-radius: 0 12px 0 0; }
.main-tab.active {
  color: var(--ocean);
  border-bottom-color: var(--ocean);
  background: #fff;
}

/* ── FILTER CHIPS ── */
.filter-chips {
  display: flex;
  gap: 6px;
  padding: 8px 12px;
  overflow-x: auto;
  scrollbar-width: none;
  background: var(--card);
  border-bottom: 1px solid var(--border);
}
.filter-chips::-webkit-scrollbar { display: none; }
.chip {
  flex-shrink: 0;
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  border: 1.5px solid var(--border);
  background: var(--bg);
  color: var(--muted);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.15s;
}
.chip.active {
  background: var(--ocean);
  border-color: var(--ocean);
  color: #fff;
}

/* ── SECTION LABEL ── */
.section-lbl {
  padding: 12px 12px 6px;
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.count-pill {
  background: var(--ocean);
  color: #fff;
  border-radius: 20px;
  padding: 1px 8px;
  font-size: 11px;
  font-weight: 700;
}

/* ── ORDER CARDS ── */
.orders-list { padding: 0 12px; display: flex; flex-direction: column; gap: 10px; }

.order-card {
  background: var(--card);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  border: 1px solid var(--border);
}

/* Card top color bar based on confirmation */
.order-card.confirmed  { border-top: 3px solid var(--fresh); }
.order-card.pending    { border-top: 3px solid var(--warn); }
.order-card.unconfirmed{ border-top: 3px solid var(--danger); }

.card-header {
  padding: 12px 14px 10px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
  border-bottom: 1px solid var(--border);
}
.order-id-badge {
  font-size: 10px;
  font-weight: 800;
  color: var(--ocean);
  background: #e8f4fd;
  border-radius: 6px;
  padding: 2px 7px;
  letter-spacing: 0.3px;
  margin-bottom: 4px;
  display: inline-block;
}
.order-name  { font-size: 15px; font-weight: 700; color: var(--text); }
.order-phone { font-size: 12px; color: var(--muted); margin-top: 2px; }
.order-time  { font-size: 10px; color: var(--muted); margin-top: 2px; opacity: 0.8; }

.card-body { padding: 10px 14px; display: flex; flex-direction: column; gap: 8px; }

/* Product / Addon items */
.items-box {
  background: #f8fafc;
  border-radius: 10px;
  padding: 8px 10px;
}
.items-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--ocean);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}
.items-text {
  font-size: 13px;
  color: var(--text);
  line-height: 1.5;
}
.addon-box {
  background: #fff8e1;
  border-radius: 10px;
  padding: 8px 10px;
}
.addon-label {
  font-size: 10px;
  font-weight: 700;
  color: #b45309;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}
.prebook-box {
  background: #f0fdf4;
  border-radius: 10px;
  padding: 8px 10px;
  border: 1px solid #bbf7d0;
}
.prebook-label {
  font-size: 10px;
  font-weight: 700;
  color: #15803d;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}

/* Address + Map */
.location-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}
.address-text {
  font-size: 12px;
  color: var(--muted);
  flex: 1;
  display: flex;
  gap: 4px;
  align-items: flex-start;
}
.map-btn {
  flex-shrink: 0;
  background: var(--ocean);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 5px 10px;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 3px;
  white-space: nowrap;
}

/* Order total */
.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--deep);
  border-radius: 10px;
  padding: 8px 12px;
}
.total-lbl  { font-size: 12px; color: rgba(255,255,255,0.7); font-weight: 600; }
.total-val  { font-size: 16px; font-weight: 800; color: var(--foam); }

/* Status grid */
.status-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
}
.stat-item { display: flex; flex-direction: column; gap: 3px; }
.stat-lbl  { font-size: 10px; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; }

/* ── PILLS ── */
.pill {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  white-space: nowrap;
}
.p-confirmed   { background: #d1fae5; color: #065f46; }
.p-pending     { background: #fef3c7; color: #92400e; }
.p-done        { background: #d1fae5; color: #065f46; }
.p-inprogress  { background: #fef3c7; color: #92400e; }
.p-notstarted  { background: #f1f5f9; color: #64748b; }
.p-dispatched  { background: #e0e7ff; color: #3730a3; }
.p-delivered   { background: #d1fae5; color: #065f46; }
.p-outdelivery { background: #ede9fe; color: #5b21b6; }
.p-paid        { background: #d1fae5; color: #065f46; }
.p-cod         { background: #fee2e2; color: #991b1b; }
.p-online      { background: #dbeafe; color: #1e40af; }
.p-prebook     { background: #f0fdf4; color: #15803d; }

/* ── EMPTY ── */
.empty { text-align: center; padding: 48px 24px; color: var(--muted); }
.empty-icon { font-size: 44px; margin-bottom: 10px; }

/* ── TOAST ── */
#toast {
  position: fixed; top: 80px; left: 50%;
  transform: translateX(-50%) translateY(-20px);
  background: var(--deep); color: #fff;
  border-radius: 14px; padding: 12px 18px;
  font-size: 13px; z-index: 999;
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  max-width: 320px; width: 90%;
  opacity: 0; transition: all 0.3s ease;
  pointer-events: none;
}
#toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
#toast .t-title { font-weight: 700; font-size: 14px; margin-bottom: 3px; }
#toast .t-body  { opacity: 0.85; font-size: 12px; }

/* ── LOADING ── */
.loading { text-align: center; padding: 40px; color: var(--muted); font-size: 14px; }
.spinner {
  width: 28px; height: 28px; border: 3px solid var(--border);
  border-top-color: var(--ocean); border-radius: 50%;
  animation: spin 0.8s linear infinite; margin: 0 auto 10px;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── LOGO UPLOAD HINT ── */
.logo-hint {
  font-size: 9px;
  color: rgba(255,255,255,0.5);
  text-align: center;
  margin-top: 2px;
}
</style>
</head>
<body>

<!-- ── HEADER ── -->
<div class="header">
  <div class="header-row1">

    <!-- Left: Brand -->
    <div class="brand-left">
      <h1>🐟 TruSea Fish</h1>
      <p>Daily Orders</p>
    </div>

    <!-- Center: Logo -->
    <div class="logo-center">
      <div class="logo-box" onclick="document.getElementById('logoUpload').click()" title="Tap to upload logo">
        <img id="logoImg" src="" alt="" style="display:none">
        <span class="logo-placeholder" id="logoPlaceholder">🐠</span>
      </div>
      <div class="logo-hint">tap to add logo</div>
      <input type="file" id="logoUpload" class="logo-upload" accept="image/*" onchange="uploadLogo(this)">
    </div>

    <!-- Right: Actions -->
    <div class="header-actions">
      <button class="icon-btn" id="bellBtn">🔔</button>
      <button class="icon-btn" onclick="manualSync()">⟳</button>
    </div>
  </div>
  <div class="sync-badge" id="syncBadge">Connecting to sheet…</div>
</div>

<!-- ── SUMMARY ── -->
<div class="summary" id="summary"></div>

<!-- ── SEARCH ── -->
<div class="search-wrap">
  <span class="search-icon">🔍</span>
  <input class="search-input" type="search" id="searchQ" placeholder="Search name, order ID, phone…" oninput="render()">
</div>

<!-- ── MAIN TABS ── -->
<div class="main-tabs">
  <button class="main-tab active" onclick="setMainTab('products', this)">🐟 Products & Add-ons</button>
  <button class="main-tab" onclick="setMainTab('prebook', this)">📅 Pre-Book</button>
</div>

<!-- ── FILTER CHIPS ── -->
<div class="filter-chips" id="filterChips">
  <button class="chip active" onclick="setFilter('all', this)">All</button>
  <button class="chip" onclick="setFilter('unconfirmed', this)">⏳ Unconfirmed</button>
  <button class="chip" onclick="setFilter('processing', this)">🔄 Processing</button>
  <button class="chip" onclick="setFilter('dispatch', this)">🚚 Dispatched</button>
  <button class="chip" onclick="setFilter('delivered', this)">✅ Delivered</button>
  <button class="chip" onclick="setFilter('pay_pending', this)">💰 Pay Pending</button>
  <button class="chip" onclick="setFilter('cod', this)">💵 COD</button>
</div>

<!-- ── ORDER LIST ── -->
<div class="section-lbl">Orders <span class="count-pill" id="orderCount">0</span></div>
<div class="orders-list" id="ordersList">
  <div class="loading"><div class="spinner"></div>Loading orders…</div>
</div>

<div id="toast"><div class="t-title" id="toastTitle"></div><div class="t-body" id="toastBody"></div></div>

<script>
// ══════════════════════════════════════════════════════
//  CONFIG
// ══════════════════════════════════════════════════════
const SHEET_ID  = '1LdJAHcoYX8ruxVEKG5j-X1KyaZohOLfhyYaUBmsVoyI';
const GID       = '1633140334'; // Sheet2
const SYNC_MINS = 10;           // Auto sync every 10 minutes

const COL = {
  timestamp:  'Timestamp',
  orderId:    'Order ID',
  name:       'Name',
  phone:      'Phone',
  address:    'Address',
  mapLink:    'Map Link',
  product:    'Product',
  addons:     'Add-ons',
  prebook:    'Pre-Book',
  price:      'Price',          // skip in display
  orderTotal: 'Order Total',
  confirm:    'Order Confirmation',
  processing: 'Processing',
  dispatch:   'Dispatch',
  delivery:   'Delivery Status',
  payMethod:  'Payment Method',
  payment:    'Payment Status',
};

const STATUS = {
  confirmed:   'Confirmed',
  pending:     'Pending',
  done:        'Done',
  inProgress:  'In Progress',
  notStarted:  'Not Started',
  dispatched:  'Dispatched',
  outDelivery: 'Out for Delivery',
  delivered:   'Delivered',
  paid:        'Paid',
  cod:         'COD',
  online:      'Online',
};
// ══════════════════════════════════════════════════════

let orders       = [];
let activeTab    = 'products';
let activeFilter = 'all';
let prevSnap     = {};
let isFirstLoad  = true;
let syncTimer    = null;
let countdown    = SYNC_MINS * 60;

// ── LOGO ──────────────────────────────────────────────
function uploadLogo(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    localStorage.setItem('trusea_logo', e.target.result);
    applyLogo(e.target.result);
  };
  reader.readAsDataURL(file);
}
function applyLogo(src) {
  const img = document.getElementById('logoImg');
  const ph  = document.getElementById('logoPlaceholder');
  img.src = src;
  img.style.display = 'block';
  ph.style.display  = 'none';
}
(function loadSavedLogo() {
  const saved = localStorage.getItem('trusea_logo');
  if (saved) applyLogo(saved);
})();

// ── FETCH ─────────────────────────────────────────────
function fetchSheet() {
  return new Promise((resolve, reject) => {
    document.querySelectorAll('script[id^="gs_"]').forEach(s => s.remove());
    Object.keys(window).filter(k => k.startsWith('__gsCB_')).forEach(k => delete window[k]);

    const cb    = '__gsCB_' + Date.now();
    const timer = setTimeout(() => { delete window[cb]; reject(new Error('Timeout')); }, 12000);

    window[cb] = function(data) {
      clearTimeout(timer);
      delete window[cb];
      try {
        if (!data.table || !data.table.rows || !data.table.rows.length)
          return reject(new Error('No data in sheet'));

        const labels = (data.table.cols || []).map(c => (c.label || '').trim());
        const fi = name => {
          if (!name) return -1;
          let i = labels.findIndex(c => c === name);
          if (i >= 0) return i;
          i = labels.findIndex(c => c.toLowerCase() === name.toLowerCase());
          if (i >= 0) return i;
          return labels.findIndex(c => c.toLowerCase().includes(name.toLowerCase()));
        };

        // Map all columns
        const idx = {
          ts:    fi(COL.timestamp),
          oid:   fi(COL.orderId),
          name:  fi(COL.name),
          phone: fi(COL.phone),
          addr:  fi(COL.address),
          map:   fi(COL.mapLink),
          prod:  fi(COL.product),
          addon: fi(COL.addons),
          pre:   fi(COL.prebook),
          total: fi(COL.orderTotal),
          conf:  fi(COL.confirm),
          proc:  fi(COL.processing),
          disp:  fi(COL.dispatch),
          deliv: fi(COL.delivery),
          pmeth: fi(COL.payMethod),
          pay:   fi(COL.payment),
        };

        const v = (r, i) => (i >= 0 && r.c[i] && r.c[i].v != null) ? String(r.c[i].v).trim() : '';
        const f = (r, i) => (i >= 0 && r.c[i]) ? (r.c[i].f || v(r,i)) : '';

        const tsVal = (r, i) => {
          if (i < 0 || !r.c[i] || r.c[i].v == null) return '';
          const raw = r.c[i].v;
          if (typeof raw === 'string' && raw.startsWith('Date(')) {
            const p = raw.replace('Date(','').replace(')','').split(',');
            const dt = new Date(+p[0], +p[1], +p[2], p[3]||0, p[4]||0);
            return dt.toLocaleString('en-IN', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit',hour12:true});
          }
          return r.c[i].f || String(raw).trim();
        };

        const rows = data.table.rows.map((r, i) => ({
          _row:       i,
          orderId:    v(r, idx.oid)  || ('#' + String(i+1).padStart(3,'0')),
          name:       v(r, idx.name),
          phone:      v(r, idx.phone),
          address:    v(r, idx.addr),
          mapLink:    v(r, idx.map),
          product:    v(r, idx.prod),
          addons:     v(r, idx.addon),
          prebook:    v(r, idx.pre),
          orderTotal: f(r, idx.total) || v(r, idx.total),
          timestamp:  tsVal(r, idx.ts),
          confirm:    v(r, idx.conf)  || STATUS.pending,
          processing: v(r, idx.proc)  || STATUS.notStarted,
          dispatch:   v(r, idx.disp)  || STATUS.pending,
          delivery:   v(r, idx.deliv) || STATUS.pending,
          payMethod:  v(r, idx.pmeth) || '—',
          payment:    v(r, idx.pay)   || STATUS.pending,
        })).filter(o => o.name && o.name.length > 1);

        resolve(rows.reverse()); // newest first
      } catch(e) { reject(e); }
    };

    const s = document.createElement('script');
    s.id  = 'gs_' + Date.now();
    s.src = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json;responseHandler:${cb}&gid=${GID}&v=${Date.now()}&r=${Math.random()}`;
    s.onerror = () => { clearTimeout(timer); reject(new Error('Failed to load sheet')); };
    document.head.appendChild(s);
  });
}

// ── SNAPSHOT for alerts ───────────────────────────────
function makeSnap(list) {
  const s = {};
  list.forEach(o => { s[o.orderId] = [o.confirm,o.processing,o.dispatch,o.delivery,o.payment].join('|'); });
  return s;
}

// ── ALERTS ───────────────────────────────────────────
function playBeep(type) {
  try {
    const ctx  = new (window.AudioContext || window.webkitAudioContext)();
    const osc  = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.setValueAtTime(type==='new' ? 520 : 440, ctx.currentTime);
    if (type==='new') osc.frequency.setValueAtTime(780, ctx.currentTime+0.15);
    gain.gain.setValueAtTime(0.35, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime+0.4);
    osc.start(ctx.currentTime); osc.stop(ctx.currentTime+0.4);
  } catch(e) {}
}

function showToast(title, body, color='#06d6a0') {
  document.getElementById('toastTitle').style.color = color;
  document.getElementById('toastTitle').textContent = title;
  document.getElementById('toastBody').textContent  = body;
  const t = document.getElementById('toast');
  t.classList.add('show');
  clearTimeout(t._t);
  t._t = setTimeout(() => t.classList.remove('show'), 4000);
}

function notify(title, body, type='new') {
  playBeep(type);
  showToast(title, body, type==='new' ? '#06d6a0' : '#fbbf24');
  if (Notification.permission === 'granted') {
    try { new Notification(title, { body, tag: type+Date.now() }); } catch(e){}
  }
}

function checkAlerts(newList) {
  if (isFirstLoad) { prevSnap = makeSnap(newList); isFirstLoad = false; return; }
  const newSnap = makeSnap(newList);
  const fresh=[], changed=[];
  newList.forEach(o => {
    if (!prevSnap[o.orderId]) fresh.push(o);
    else if (prevSnap[o.orderId] !== newSnap[o.orderId]) changed.push(o);
  });
  if (fresh.length)   notify(`🐟 ${fresh.length} New Order${fresh.length>1?'s':''}!`, fresh.map(o=>o.name).join(', '), 'new');
  changed.forEach(o => notify('🔄 Order Updated', `${o.name} · ${o.delivery}`, 'change'));
  prevSnap = newSnap;
}

// ── SYNC ─────────────────────────────────────────────
async function sync(silent=false) {
  if (!silent) document.getElementById('syncBadge').textContent = 'Syncing…';
  try {
    const live = await fetchSheet();
    if (live.length) {
      checkAlerts(live);
      orders = live;
      const t = new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
      document.getElementById('syncBadge').textContent = `✓ Live · ${live.length} orders · ${t}`;
      if (!silent) showToast('✓ Synced', `${live.length} orders loaded`, '#06d6a0');
    } else throw new Error('empty');
  } catch(e) {
    document.getElementById('syncBadge').textContent = '⚠ Sheet not reachable · demo mode';
    if (!orders.length) orders = DEMO;
    if (!silent) showToast('⚠ Demo mode', 'Make sheet public to connect', '#fbbf24');
  }
  render();
  resetCountdown();
}

function manualSync() { sync(false); }

function resetCountdown() {
  clearInterval(syncTimer);
  countdown = SYNC_MINS * 60;
  syncTimer = setInterval(() => {
    countdown--;
    const m = Math.floor(countdown/60), s = countdown%60;
    const badge = document.getElementById('syncBadge');
    if (badge.textContent.startsWith('✓')) {
      const base = badge.textContent.split('·').slice(0,2).join('·');
      badge.textContent = base + ` · next sync ${m}:${String(s).padStart(2,'0')}`;
    }
    if (countdown <= 0) sync(true);
  }, 1000);
}

// ── TABS & FILTERS ────────────────────────────────────
function setMainTab(tab, el) {
  activeTab = tab;
  document.querySelectorAll('.main-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  render();
}

function setFilter(f, el) {
  activeFilter = f;
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  render();
}

function applyFilter(list) {
  switch(activeFilter) {
    case 'unconfirmed': return list.filter(o => o.confirm !== STATUS.confirmed);
    case 'processing':  return list.filter(o => o.processing === STATUS.inProgress);
    case 'dispatch':    return list.filter(o => o.dispatch === STATUS.dispatched);
    case 'delivered':   return list.filter(o => o.delivery === STATUS.delivered);
    case 'pay_pending': return list.filter(o => o.payment === STATUS.pending);
    case 'cod':         return list.filter(o => o.payMethod === STATUS.cod);
    default:            return list;
  }
}

// ── RENDER ────────────────────────────────────────────
function render() {
  const q = document.getElementById('searchQ').value.toLowerCase().trim();

  // Tab filter
  let list = orders.filter(o => {
    if (activeTab === 'prebook') return o.prebook && o.prebook.trim() !== '';
    return true; // products tab shows all
  });

  // Search
  if (q) list = list.filter(o =>
    [o.name, o.phone, o.orderId, o.product, o.address, o.addons, o.prebook].join(' ').toLowerCase().includes(q)
  );

  // Status filter
  list = applyFilter(list);

  // Summary (always full orders)
  const t = orders.length || 1;
  document.getElementById('summary').innerHTML = [
    { num: orders.length,                                               lbl: 'Total',    cls: 'c-blue'   },
    { num: orders.filter(o=>o.confirm===STATUS.confirmed).length,       lbl: 'Confirmed',cls: 'c-green'  },
    { num: orders.filter(o=>o.delivery===STATUS.outDelivery||o.dispatch===STATUS.dispatched).length, lbl: 'Dispatched',cls:'c-orange'},
    { num: orders.filter(o=>o.payment===STATUS.pending).length,         lbl: 'Pay Due',  cls: 'c-red'    },
  ].map(s=>`<div class="sum-card"><div class="sum-num ${s.cls}">${s.num}</div><div class="sum-lbl">${s.lbl}</div></div>`).join('');

  document.getElementById('orderCount').textContent = list.length;

  if (!list.length) {
    document.getElementById('ordersList').innerHTML =
      `<div class="empty"><div class="empty-icon">📭</div><div>No orders found</div></div>`;
    return;
  }

  document.getElementById('ordersList').innerHTML = list.map(o => {
    // Card top border color
    const cardCls = o.confirm === STATUS.confirmed ? 'confirmed' :
                    o.confirm === STATUS.pending    ? 'pending'   : 'unconfirmed';

    // Format products with pipe separator
    const prodHtml = o.product
      ? o.product.split('\n').filter(l=>l.trim()).join(' | ')
      : '';
    const addonHtml = o.addons
      ? o.addons.split('\n').filter(l=>l.trim()).join(' | ')
      : '';
    const prebookHtml = o.prebook
      ? o.prebook.split('\n').filter(l=>l.trim()).join(' | ')
      : '';

    return `
    <div class="order-card ${cardCls}">

      <div class="card-header">
        <div style="flex:1;min-width:0">
          <div class="order-id-badge">${o.orderId}</div>
          <div class="order-name">${o.name}</div>
          <div class="order-phone">📞 ${o.phone || '—'}</div>
          ${o.timestamp ? `<div class="order-time">🕐 ${o.timestamp}</div>` : ''}
        </div>
        <span class="${pill(o.confirm)}">${o.confirm}</span>
      </div>

      <div class="card-body">

        ${prodHtml ? `
        <div class="items-box">
          <div class="items-label">🐟 Products</div>
          <div class="items-text">${prodHtml}</div>
        </div>` : ''}

        ${addonHtml ? `
        <div class="addon-box">
          <div class="addon-label">➕ Add-ons</div>
          <div class="items-text">${addonHtml}</div>
        </div>` : ''}

        ${prebookHtml ? `
        <div class="prebook-box">
          <div class="prebook-label">📅 Pre-Book</div>
          <div class="items-text">${prebookHtml}</div>
        </div>` : ''}

        ${o.address ? `
        <div class="location-row">
          <div class="address-text">📍 ${o.address}</div>
          ${o.mapLink ? `<a class="map-btn" href="${o.mapLink}" target="_blank">🗺 Map</a>` : ''}
        </div>` : ''}

        ${o.orderTotal ? `
        <div class="total-row">
          <div class="total-lbl">Order Total</div>
          <div class="total-val">₹${o.orderTotal}</div>
        </div>` : ''}

        <div class="status-grid">
          <div class="stat-item">
            <div class="stat-lbl">Processing</div>
            <span class="${pill(o.processing)}">${o.processing}</span>
          </div>
          <div class="stat-item">
            <div class="stat-lbl">Dispatch</div>
            <span class="${pill(o.dispatch)}">${o.dispatch}</span>
          </div>
          <div class="stat-item">
            <div class="stat-lbl">Delivery</div>
            <span class="${pill(o.delivery)}">${o.delivery}</span>
          </div>
          <div class="stat-item">
            <div class="stat-lbl">Payment</div>
            <span class="${pill(o.payment)}">${o.payment}${o.payMethod && o.payMethod!=='—' ? ' · '+o.payMethod : ''}</span>
          </div>
        </div>

      </div>
    </div>`;
  }).join('');
}

// ── PILL helper ───────────────────────────────────────
function pill(v) {
  const m = {
    [STATUS.confirmed]:   'pill p-confirmed',
    [STATUS.pending]:     'pill p-pending',
    [STATUS.done]:        'pill p-done',
    [STATUS.inProgress]:  'pill p-inprogress',
    [STATUS.notStarted]:  'pill p-notstarted',
    [STATUS.dispatched]:  'pill p-dispatched',
    [STATUS.delivered]:   'pill p-delivered',
    [STATUS.outDelivery]: 'pill p-outdelivery',
    [STATUS.paid]:        'pill p-paid',
    [STATUS.cod]:         'pill p-cod',
    [STATUS.online]:      'pill p-online',
  };
  return m[v] || 'pill p-pending';
}

